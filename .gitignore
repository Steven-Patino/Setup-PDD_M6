dbt/target/
dbt/dbt_packages/
dbt/logs/

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Docker
.docker/

# Sistema operativo
.DS_Store
Thumbs.db
