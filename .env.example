# =============================================================================
# .env.example — Plantilla de configuración
# =============================================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores de la sección "BASE DE DATOS EXTERNA"
#   3. NUNCA subas el archivo .env a Git (ya está en .gitignore)
#
# CÓMO FLUYEN LAS CREDENCIALES:
#   .env ──► docker-compose.yaml (environment:) ──► Contenedor de Airflow
#                                                         │
#                                                    dbt/profiles.yml
#                                                    (lee con env_var())
# =============================================================================


# -----------------------------------------------------------------------------
# AIRFLOW — Configuración del entorno
# -----------------------------------------------------------------------------

# UID del usuario del sistema operativo del host que ejecuta Docker.
# En Linux: ejecuta `id -u` en la terminal para obtener el valor correcto.
# En Windows/Mac con Docker Desktop: dejar el valor por defecto (50000).
AIRFLOW_UID=50000

# Clave de cifrado para conexiones y variables almacenadas en Airflow.
# Generada con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️  Para uso LOCAL: mantener este valor fijo garantiza consistencia entre reinicios.
# ⚠️  Para PRODUCCIÓN: generar una clave única y mantenerla en un gestor de secretos.
AIRFLOW__CORE__FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# Credenciales para acceder a la UI web de Airflow (http://localhost:8080)
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin


# -----------------------------------------------------------------------------
# BASE DE DATOS EXTERNA — PostgreSQL en la nube (target de dbt)
# -----------------------------------------------------------------------------
# Estos valores son los ÚNICOS que necesitas editar para conectar tu proyecto.
# Son leídos por dbt/profiles.yml a través de la función {{ env_var('...') }}.
# Airflow los hereda del entorno Docker automáticamente.
# -----------------------------------------------------------------------------

DBT_DB_HOST=your-cloud-db-host.example.com
DBT_DB_PORT=5432
DBT_DB_USER=your_db_username
DBT_DB_PASSWORD=your_secure_password
DBT_DB_NAME=your_database_name
DBT_DB_SCHEMA=public
