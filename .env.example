# =============================================================================
# .env.example — Plantilla de configuración del entorno
# =============================================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env  (o en Windows: copy .env.example .env)
#   2. Completa los valores de la sección "BASE DE DATOS EXTERNA"
#   3. NUNCA subas el archivo .env al repositorio (ya está en .gitignore)
#
# FLUJO DE LAS CREDENCIALES:
#   .env  ──►  docker-compose.yaml (environment:)
#                  │
#                  ├──►  Contenedor Airflow  ──►  dbt/profiles.yml (env_var())
#                  └──►  airflow-init  ──►  airflow connections add  ──►  DAG
# =============================================================================


# -----------------------------------------------------------------------------
# AIRFLOW — Configuración interna
# -----------------------------------------------------------------------------

# En Linux: ejecuta `id -u` en la terminal. En Windows/Mac con Docker Desktop: dejar 50000.
AIRFLOW_UID=50000

# Clave de cifrado para conexiones y variables en Airflow.
# Para uso LOCAL mantener este valor fijo (garantiza consistencia entre reinicios).
# Para PRODUCCIÓN: generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# Credenciales del usuario administrador de la UI web de Airflow
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin


# -----------------------------------------------------------------------------
# BASE DE DATOS EXTERNA — PostgreSQL (Data Warehouse del proyecto)
# -----------------------------------------------------------------------------
# Estos son los ÚNICOS valores que necesitas editar para conectar tu proyecto.
# Son leídos por:
#   1. dbt/profiles.yml: a través de {{ env_var('DBT_DB_HOST') }} etc.
#   2. airflow-init:     para registrar la Airflow Connection 'postgres_datamart'
#   3. El DAG:           a través de la Connection 'postgres_datamart'
# -----------------------------------------------------------------------------

DBT_DB_HOST=15.204.173.204
DBT_DB_PORT=6432
DBT_DB_USER=coder-ra-c6
DBT_DB_PASSWORD=Riwi2026**
DBT_DB_NAME=steven_patino
DBT_DB_SCHEMA=public
